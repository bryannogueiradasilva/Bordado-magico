{
  "rules": {
    "products": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'manager' || auth.token.email == 'bryannogueira07@gmail.com')"
    },
    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'manager' || auth.token.email == 'bryannogueira07@gmail.com')",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'manager' || auth.token.email == 'bryannogueira07@gmail.com')",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'manager' || auth.token.email == 'bryannogueira07@gmail.com')"
      }
    },
    "orders": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'manager' || auth.token.email == 'bryannogueira07@gmail.com')",
      ".write": "auth != null"
    },
    "config": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'manager' || auth.token.email == 'bryannogueira07@gmail.com')"
    }
  }
}
